TOGETHER_API_KEY=

# Recommended Together setup for specialist authoring
CONTROLLER_MODEL=MiniMaxAI/MiniMax-M2.5
SPECIALIST_COMPILER_MODEL=zai-org/GLM-5
EXTRACTION_MODEL=zai-org/GLM-5
SPECIALIST_CRITIC_MODEL=MiniMaxAI/MiniMax-M2.5
FAST_MODEL=MiniMaxAI/MiniMax-M2.5

# Optional generic fallback
TOGETHER_MODEL=openai/gpt-oss-120b

SPECIALIST_BOT_TOKEN=
USER_BOT_TOKEN=
PROVIDER_TIMEOUT_SECONDS=240
CONTROLLER_REQUEST_TIMEOUT_SECONDS=360

SPECIALIST_CONTROLLER_HOST=http://localhost:8107
PATIENT_CONTROLLER_HOST=http://localhost:8106

HEA_DB_PATH=data/hea.sqlite
LOG_LEVEL=INFO
